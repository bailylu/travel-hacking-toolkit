# Travel Hacking Toolkit - API Keys Configuration
# Copy this file to .env and fill in your API keys.
#
# ⚠️  REQUIRED - You must fill in these keys:
# ============================================================

# SerpAPI - Google Hotels search (international)
# Free tier: 100 searches/month at https://serpapi.com
# Sign up and get your API key from https://serpapi.com/dashboard
SERPAPI_API_KEY=YOUR_SERPAPI_API_KEY_HERE

# FlyAI (Fliggy) - China domestic travel (flights, hotels, attractions, trains)
# Get your API key from 飞猪开放平台: https://open.fliggy.com/
FLYAI_API_KEY=YOUR_FLYAI_API_KEY_HERE


# ============================================================
# OPTIONAL - Already configured or not needed:
# ============================================================

# Fli - Google Flights CLI (international flights)
# No API key needed! Install with: pipx install flights
# Or use the venv: ~/.local/share/venvs/fli/bin/fli
# CLI usage: fli flights JFK LAX 2026-05-01

# Premium Hotels - FHR/Chase Edit property lookup
# No API key needed! Local JSON data in skills/premium-hotels/data/
# Used for Amex FHR / THC / Chase Edit searches by city


# ============================================================
# v2 DEFERRED - Not yet implemented:
# ============================================================

# Seats.aero - Award flight availability (25+ mileage programs)
# Get a Pro or Partner account at https://seats.aero
# Commented out - coming in v2
# SEATS_AERO_API_KEY=YOUR_SEATS_AERO_API_KEY

# AwardWallet - All loyalty balances and elite status
# Business account required: https://business.awardwallet.com/profile/api
# Commented out - coming in v2
# AWARDWALLET_API_KEY=YOUR_AWARDWALLET_API_KEY
# AWARDWALLET_USER_ID=YOUR_AWARDWALLET_USER_ID
