# Travel Hacking Toolkit - API Keys Configuration
# Copy this file to .env and fill in your API keys.
# Only the keys you need - not all are required.

# ============================================================
# FLIGHT SEARCH (choose one or more)
# ============================================================

# Fli - Google Flights (RECOMMENDED - no API key needed, covers ALL airlines)
# Installed by default: `pipx install flights`
# CLI: fli flights JFK LAX 2026-05-01

# Duffel - Real GDS cash prices, bookable
# Sign up at https://duffel.com
# Search is free, pay only if you book
DUFFEL_API_KEY_LIVE=your_duffel_live_token_here

# Airlabs - Flight tracking, real-time positions, schedules
# Sign up at https://airlabs.co
AIRLABS_API_KEY=your_airlabs_api_key_here

# Ignav - Fast REST API for cash prices
# 1,000 free requests at https://ignav.com/signup
IGNAV_API_KEY=your_ignav_api_key_here

# Seats.aero - Award flight availability (25+ programs)
# Get a Pro or Partner account at https://seats.aero
SEATS_AERO_API_KEY=your_seats_aero_api_key_here


# ============================================================
# HOTELS (optional)
# ============================================================

# SerpAPI - Google Hotels search, destination discovery
# Free tier: 100 searches/month at https://serpapi.com
SERPAPI_API_KEY=your_airlabs_api_key_here

# RapidAPI - Booking.com hotel prices
# Free tier: 100 req/month at https://rapidapi.com
RAPIDAPI_KEY=your_rapidapi_key_here

# LiteAPI - Hotel search with live rates
# Sign up at https://liteapi.travel
LITEAPI_API_KEY=your_liteapi_key_here

# TripAdvisor Content API - Hotel ratings, reviews, nearby
# 5,000 calls/month at https://www.tripadvisor.com/developers
TRIPADVISOR_API_KEY=your_tripadvisor_api_key_here


# ============================================================
# LOYALTY TRACKING (optional)
# ============================================================

# AwardWallet - All loyalty balances and elite status
# Business account required: https://business.awardwallet.com/profile/api
AWARDWALLET_API_KEY=
AWARDWALLET_USER_ID=


# ============================================================
# SCANDINAVIA TRANSIT (optional - for Nordic travel)
# ============================================================

# Entur (Norway) - Just needs a descriptive client name
ENTUR_CLIENT_NAME=yourname-tripplanner

# ResRobot (Sweden) - Free key from https://www.trafiklab.se
RESROBOT_API_KEY=your_resrobot_key_here

# Rejseplanen (Denmark) - Free key, apply at https://labs.rejseplanen.dk
REJSEPLANEN_API_KEY=your_rejseplanen_key_here


# ============================================================
# PORTAL LOGINS (optional - requires Docker for some)
# ============================================================

# Southwest credentials for fare search + price drop monitor
SW_USERNAME=
SW_PASSWORD=

# American Airlines credentials for AAdvantage balance check
AA_USERNAME=
AA_PASSWORD=

# Chase Travel (Sapphire Reserve/Preferred) - UR portal pricing
CHASE_USERNAME=
CHASE_PASSWORD=

# Amex Travel (Platinum) - MR portal pricing, FHR/THC
AMEX_USERNAME=
AMEX_PASSWORD=
