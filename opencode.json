{
  "$schema": "https://opencode.ai/config-schema.json",
  "mcp": {
    "skiplagged": {
      "type": "remote",
      "url": "https://mcp.skiplagged.com/mcp",
      "enabled": true
    },
    "kiwi": {
      "type": "remote",
      "url": "https://mcp.kiwi.com",
      "enabled": true
    },
    "trivago": {
      "type": "remote",
      "url": "https://mcp.trivago.com/mcp",
      "enabled": true
    },
    "ferryhopper": {
      "type": "remote",
      "url": "https://mcp.ferryhopper.com/mcp",
      "enabled": true
    },
    "airbnb": {
      "type": "local",
      "command": ["npx", "-y", "@openbnb/mcp-server-airbnb@latest", "--ignore-robots-txt"],
      "enabled": true
    },
    "fli": {
      "type": "local",
      "command": ["fli-mcp"],
      "enabled": true
    }
  }
}
